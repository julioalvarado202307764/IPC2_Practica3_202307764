@page
@model Practica3_Razor.Pages.IndexModel
@{
    ViewData["Title"] = "Inventario del Supermercado";
}

<div class="container mt-4">
    <h1 class="mb-4 text-center">Gestión de Inventario</h1>

    <div class="mb-3">
        <a asp-page="/Crear" class="btn btn-primary"> Agregar Nuevo Producto</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Vencimiento</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Productos != null && Model.Productos.Any())
                {
                    @foreach (var producto in Model.Productos)
                    {
                        <tr>
                            <td>@producto.Id</td>
                            <td class="fw-bold">@producto.Nombre</td>
                            <td><span class="badge bg-secondary">@producto.Categoria</span></td>
                            <td>Q @producto.Precio.ToString("0.00")</td>
                            <td>
                                @if (producto.CantidadEnStock <= 5)
                                {
                                    <span class="text-danger fw-bold">@producto.CantidadEnStock (Bajo)</span>
                                }
                                else
                                {
                                    @producto.CantidadEnStock
                                }
                            </td>
                            <td>@(producto.FechaVencimiento.HasValue ? producto.FechaVencimiento.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                            <td>
                                <a asp-page="/Editar" asp-route-id="@producto.Id" class="btn btn-warning btn-sm"> Editar</a>
                                <a asp-page="/Eliminar" asp-route-id="@producto.Id" class="btn btn-danger btn-sm"> Eliminar</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4">No hay productos en el inventario. ¡Agrega uno nuevo!</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>