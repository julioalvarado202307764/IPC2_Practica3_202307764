@page "{id:int}"
@model Practica3_Razor.Pages.EditarModel
@{
    ViewData["Title"] = "Editar Producto";
}

<div class="container mt-4">
    <h2 class="text-center"> Editar Producto</h2>
    <hr />

    <div class="row justify-content-center">
        <div class="col-md-6 shadow-sm p-4 bg-light rounded">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="ProductoEditar.Id" />

                <div class="mb-3">
                    <label asp-for="ProductoEditar.Nombre" class="form-label fw-bold">Nombre del Producto</label>
                    <input asp-for="ProductoEditar.Nombre" class="form-control" />
                    <span asp-validation-for="ProductoEditar.Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductoEditar.Categoria" class="form-label fw-bold">Categoría</label>
                    <input asp-for="ProductoEditar.Categoria" class="form-control" />
                    <span asp-validation-for="ProductoEditar.Categoria" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductoEditar.Descripcion" class="form-label fw-bold">Descripción (Opcional)</label>
                    <textarea asp-for="ProductoEditar.Descripcion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="ProductoEditar.Descripcion" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ProductoEditar.Precio" class="form-label fw-bold">Precio (Q)</label>
                        <input asp-for="ProductoEditar.Precio" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="ProductoEditar.Precio" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ProductoEditar.CantidadEnStock" class="form-label fw-bold">Stock</label>
                        <input asp-for="ProductoEditar.CantidadEnStock" type="number" class="form-control" />
                        <span asp-validation-for="ProductoEditar.CantidadEnStock" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductoEditar.FechaVencimiento" class="form-label fw-bold">Fecha de Vencimiento (Opcional)</label>
                    <input asp-for="ProductoEditar.FechaVencimiento" type="date" class="form-control" />
                    <span asp-validation-for="ProductoEditar.FechaVencimiento" class="text-danger"></span>
                </div>

                <div class="mt-4 d-flex justify-content-center gap-2">
                    <button type="submit" class="btn btn-warning"> Actualizar Producto</button>
                    <a asp-page="/Index" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}